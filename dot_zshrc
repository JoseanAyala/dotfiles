# History
HISTFILE=$HOME/.zsh_history
HISTSIZE=100000
SAVEHIST=100000
setopt SHARE_HISTORY HIST_IGNORE_ALL_DUPS HIST_IGNORE_SPACE EXTENDED_HISTORY HIST_REDUCE_BLANKS

# Options
setopt AUTO_CD AUTO_PUSHD PUSHD_IGNORE_DUPS INTERACTIVE_COMMENTS EXTENDED_GLOB CORRECT

# Editor
export EDITOR=nvim
export VISUAL=nvim

# fzf
export FZF_DEFAULT_COMMAND='fd --type f --hidden --follow --exclude .git'
export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"
export FZF_ALT_C_COMMAND='fd --type d --hidden --follow --exclude .git'
export FZF_DEFAULT_OPTS='--height 40% --layout=reverse --border --info=inline'

# Plugins via antidote
source /opt/homebrew/opt/antidote/share/antidote/antidote.zsh
autoload -Uz compinit && compinit
antidote load

# Prompt and shell integrations
eval "$(starship init zsh)"
eval "$(mise activate zsh)"
eval "$(zoxide init --cmd=cd zsh)"
eval "$(direnv hook zsh)"
source <(fzf --zsh)

# kubectl
alias k=kubectl
compdef k=kubectl

# git
alias gs='git status'
alias gd='git diff'
alias gco='git checkout'
alias gcb='git checkout -b'
alias gl='git log --oneline --decorate --graph'
alias gp='git pull'
alias gP='git push'

# docker
alias d='docker'
alias dc='docker compose'
alias dps='docker ps'

# eza (modern ls)
alias ls='eza --icons --group-directories-first'
alias l='eza -l --icons --group-directories-first --git --time-style=relative'
alias la='eza -la --icons --group-directories-first --git --time-style=relative'
alias lt='eza --tree --level=2 --icons --group-directories-first'

# bat (modern cat)
alias cat='bat --paging=never'

# misc
alias cls='clear'
alias vim='nvim'
alias gg='lazygit'
alias cc='claude'
alias z='cd'

# functions
kpf()   { kubectl port-forward "$@"; }
kexec() { local p=$1; shift; kubectl exec -it "$p" -- "${@:-sh}"; }
klogs() { kubectl logs -f "$@"; }
docker-gc() { docker system prune -af --volumes; }

# Machine-local overrides (secrets, per-host PATH, etc) — not tracked by chezmoi
[ -f ~/.zshrc.local ] && source ~/.zshrc.local
